{
  "name": "polyglow",
  "description": "A multilingual Astro 6 theme for content-first publishing.",
  "type": "module",
  "version": "6.0.0",
  "homepage": "https://polyglow.idimi.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/idimilabs/Polyglow.git"
  },
  "keywords": [
    "astro",
    "theme",
    "blog",
    "i18n",
    "tailwind",
    "seo",
    "multilingual"
  ],
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild"
    ]
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "astro": "astro",
    "dev": "astro dev",
    "build": "astro build",
    "check": "pnpm exec tsc --noEmit && astro build",
    "preview": "astro preview",
    "format": "prettier --write .",
    "deploy": "pnpm exec wrangler deploy"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.0",
    "@astrojs/partytown": "^2.1.4",
    "@astrojs/rss": "^4.0.14",
    "@astrojs/sitemap": "^3.7.1",
    "@tailwindcss/vite": "^4.1.12",
    "astro": "^6.1.1",
    "astro-expressive-code": "^0.41.3",
    "astro-icon": "^1.1.5",
    "astro-pagefind": "^1.8.6",
    "astro-seo": "^1.0.0",
    "dayjs": "^1.11.13",
    "tailwindcss": "^4.1.12"
  },
  "devDependencies": {
    "@astrojs/cloudflare": "^13.1.4",
    "@iconify-json/lucide": "^1.2.81",
    "@tailwindcss/typography": "^0.5.16",
    "prettier": "3.8.3",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-tailwindcss": "0.6.14",
    "sharp": "^0.34.5",
    "typescript": "5.9.3",
    "wrangler": "^4.77.0"
  }
}
